# NebulaForge X - Production Environment Variables
# DO NOT commit this file with real secrets

# Application
NODE_ENV=production
VITE_APP_NAME="NebulaForge X"
VITE_APP_VERSION="1.0.0"
VITE_APP_DESCRIPTION="AI-Powered 3D Game Engine Platform"

# API Configuration
VITE_API_URL=https://nebulaforge.com/api
VITE_WS_URL=wss://nebulaforge.com/ws
VITE_CDN_URL=https://cdn.nebulaforge.com

# Authentication
VITE_AUTH_DOMAIN=nebulaforge.com
VITE_AUTH_CLIENT_ID=your_auth_client_id
VITE_GOOGLE_CLIENT_ID=your_google_client_id
VITE_GITHUB_CLIENT_ID=your_github_client_id

# Features
VITE_ENABLE_AI=true
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_MONITORING=true
VITE_ENABLE_COLLABORATION=true
VITE_ENABLE_API_ACCESS=true

# Analytics
VITE_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
VITE_MIXPANEL_TOKEN=your_mixpanel_token
VITE_HOTJAR_ID=your_hotjar_id

# Monitoring
VITE_SENTRY_DSN=your_sentry_dsn
VITE_LOGROCKET_ID=your_logrocket_id

# Social Media
VITE_TWITTER_HANDLE=@NebulaForgeX
VITE_DISCORD_INVITE=https://discord.gg/nebulaforge
VITE_GITHUB_REPO=https://github.com/YourUsername/NebulaForge-X

# Performance
VITE_ENABLE_PWA=true
VITE_ENABLE_SERVICE_WORKER=true
VITE_ENABLE_OFFLINE_MODE=true

# AI Configuration
VITE_AI_MODELS_URL=https://models.nebulaforge.com
VITE_AI_PROCESSING_URL=https://ai.nebulaforge.com

# Game Engine
VITE_ASSETS_CDN=https://assets.nebulaforge.com
VITE_TEMPLATES_URL=https://templates.nebulaforge.com
VITE_EXPORTS_URL=https://exports.nebulaforge.com

# Legal
VITE_PRIVACY_POLICY_URL=https://nebulaforge.com/privacy
VITE_TERMS_OF_SERVICE_URL=https://nebulaforge.com/terms
VITE_SUPPORT_EMAIL=support@nebulaforge.com

# Rate Limiting
VITE_API_RATE_LIMIT=1000
VITE_AI_RATE_LIMIT=100

# Feature Flags
VITE_BETA_FEATURES=false
VITE_EXPERIMENTAL_UI=false
VITE_DEBUG_MODE=false